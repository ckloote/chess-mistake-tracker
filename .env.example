# Path to the SQLite database file. The parent directory is created on app startup.
CHESS_DB_PATH=./data/chess.db

# Lichess username for the single user. Required.
LICHESS_USERNAME=your_lichess_username

# Comma-separated list of Lichess study IDs to import as games.
LICHESS_STUDY_IDS=

# Alternative player names that should be treated as the configured user when
# matching study chapter [White]/[Black] tags. Useful for OTB studies where you
# record yourself by real name or initials. Case-insensitive, comma-separated.
# Example: STUDY_PLAYER_ALIASES=CJK,Christopher Kloote
STUDY_PLAYER_ALIASES=

# Mistake-detection thresholds (win% drop). Defaults match DESIGN.md.
WINRATE_INACCURACY=5
WINRATE_MISTAKE=10
WINRATE_BLUNDER=20

# Suppression bounds (DESIGN.md §"Detection algorithm" steps 4 & 5).
# Below SUPPRESS_BELOW: already losing; not "giving away an advantage."
# Above SUPPRESS_ABOVE_BEFORE/AFTER: still very much winning despite imprecision.
SUPPRESS_BELOW=30
SUPPRESS_ABOVE_BEFORE=90
SUPPRESS_ABOVE_AFTER=80
